{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/123xiaoxin/master-orchestrator/schemas/agent_pack.v1.schema.json",
  "title": "Master Orchestrator Agent Pack v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "maxAgents", "execution", "cleanupPolicy", "agents"],
  "properties": {
    "schemaVersion": {
      "enum": ["agent_pack.v1"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "maxAgents": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "execution": {
      "type": "string"
    },
    "cleanupPolicy": {
      "enum": ["ask", "destroy", "keep", "archive-template"]
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "role", "dependsOn"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "role": {
            "type": "string"
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" }
          },
          "microSop": {
            "type": "object",
            "additionalProperties": true,
            "required": ["context", "deliverable", "negativeConstraints", "exitCondition", "budget"],
            "properties": {
              "context": { "type": "string" },
              "deliverable": { "type": "string" },
              "negativeConstraints": {
                "type": "array",
                "items": { "type": "string" }
              },
              "exitCondition": { "type": "string" },
              "budget": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "tokenBudget": { "type": ["integer", "null"], "minimum": 0 },
                  "maxRounds": { "type": ["integer", "null"], "minimum": 1 },
                  "timeoutMinutes": { "type": ["integer", "null"], "minimum": 1 },
                  "heartbeat": { "const": 0 }
                }
              }
            }
          }
        }
      }
    }
  }
}
