{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/123xiaoxin/master-orchestrator/schemas/agent_pack.v1.schema.json",
  "title": "Master Orchestrator Agent Pack v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "name",
    "maxAgents",
    "execution",
    "cleanupPolicy",
    "agents"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agent_pack.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "maxAgents": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "execution": {
      "type": "string"
    },
    "cleanupPolicy": {
      "enum": [
        "ask",
        "destroy",
        "keep",
        "archive-template"
      ]
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "role",
          "dependsOn",
          "microSop"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "role": {
            "type": "string"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "microSop": {
            "$ref": "micro_sop.v1.schema.json"
          }
        }
      }
    }
  }
}
