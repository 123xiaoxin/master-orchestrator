{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/123xiaoxin/master-orchestrator/schemas/task_analysis.v1.schema.json",
  "title": "Master Orchestrator Task Analysis v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "intent",
    "goal",
    "nonGoals",
    "deliverables",
    "constraints",
    "successCriteria",
    "capabilityMapping",
    "routingDecision"
  ],
  "properties": {
    "schemaVersion": {
      "const": "task_analysis.v1"
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "environmentSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "maxSpawnDepth": { "type": ["integer", "null"] },
        "maxChildrenPerAgent": { "type": ["integer", "null"] },
        "availableModels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expertLibraryAvailable": { "type": "boolean" },
        "userAgentsBypassed": { "type": "boolean" }
      }
    },
    "capabilityMapping": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capability", "required", "matchedBy", "fallback"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "matchedBy": { "type": "string" },
          "fallback": { "type": "string" }
        }
      }
    },
    "routingDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "reason"],
      "properties": {
        "mode": {
          "enum": [
            "master_only",
            "create_temp_agent",
            "create_subagent",
            "create_agent_pack",
            "staged_execution",
            "downgrade_or_clarify"
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "agentCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    }
  }
}
